{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Sessions Started",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(claude_code_session_count_total) or vector(0)",
          "legendFormat": "Sessions"
        }
      ]
    },
    {
      "title": "Total Cost (USD)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "currencyUSD",
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 20 }] }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(claude_code_cost_usage_total) or vector(0)",
          "legendFormat": "Cost"
        }
      ]
    },
    {
      "title": "Total Tokens Used",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": null }] } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(claude_code_token_usage_total) or vector(0)",
          "legendFormat": "Tokens"
        }
      ]
    },
    {
      "title": "Lines of Code Modified",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "purple", "value": null }] } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(claude_code_lines_of_code_count_total) or vector(0)",
          "legendFormat": "Lines"
        }
      ]
    },
    {
      "title": "Tokens by Type Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 20 } }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (type) (rate(claude_code_token_usage_total[5m]))",
          "legendFormat": "{{type}}"
        }
      ]
    },
    {
      "title": "Cost Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "custom": { "drawStyle": "line", "fillOpacity": 20 } }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(rate(claude_code_cost_usage_total[5m]))",
          "legendFormat": "Cost/s"
        }
      ]
    },
    {
      "title": "Commits & PRs",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 80 } }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(increase(claude_code_commit_count_total[5m]))",
          "legendFormat": "Commits"
        },
        {
          "expr": "sum(increase(claude_code_pull_request_count_total[5m]))",
          "legendFormat": "PRs"
        }
      ]
    },
    {
      "title": "Active Time (seconds)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 20 } }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(rate(claude_code_active_time_total_total[5m]))",
          "legendFormat": "Active time/s"
        }
      ]
    },
    {
      "title": "Code Edit Tool Decisions",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 80 } }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (decision) (increase(claude_code_code_edit_tool_decision_total[5m]))",
          "legendFormat": "{{decision}}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["claude-code", "otel"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Claude Code Monitoring",
  "uid": "claude-code-monitoring",
  "version": 1
}
